# Foundation Swarm — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — AI Provider
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key (required for all agents)
OPENAI_API_KEY=your_openai_api_key_here

# Default model (gpt-5.2 recommended; falls back to gpt-4o-mini if not set)
DEFAULT_MODEL=gpt-5.2

# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT AGENT
# ─────────────────────────────────────────────────────────────────────────────

# Candid (GuideStar) API — funder profile data
# Register free at: https://candid.org/our-products/apis
CANDID_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# RESEARCH AGENT
# ─────────────────────────────────────────────────────────────────────────────

# NewsAPI — news digests and monitoring
# Register free at: https://newsapi.org
NEWS_API_KEY=

# US Census Bureau API — community data for grant narratives
# Register free at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# LegiScan API — California and federal bill tracking
# Register free at: https://legiscan.com/legiscan
LEGISCAN_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# VIRTUAL ASSISTANT — Optional Live Integrations
# ─────────────────────────────────────────────────────────────────────────────
# The Virtual Assistant works FULLY without these integrations.
# Enable ONLY after confirming access with LFLA IT and org approval.
# All integrations are gated behind VA_INTEGRATIONS_ENABLED=true.

# Master switch — enables ExecuteTool/ManageConnections/SearchTools/FindTools
# Default: false — agent works in file-upload/manual-input mode
VA_INTEGRATIONS_ENABLED=false

# Individual integration flags (only relevant if VA_INTEGRATIONS_ENABLED=true)
# Enable only the specific integrations that have been approved
VA_GMAIL_ENABLED=false       # Gmail access — requires Google Workspace admin approval
VA_OUTLOOK_ENABLED=false     # Outlook/Exchange — requires IT approval
VA_GCAL_ENABLED=false        # Google Calendar — requires org Google account access
VA_GDRIVE_ENABLED=false      # Google Drive — requires org Google account access
VA_NOTION_ENABLED=false      # Notion — lower IT friction; can enable independently

# Composio API key (required only if VA_INTEGRATIONS_ENABLED=true)
# Register at: https://composio.dev
COMPOSIO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# IMAGE GENERATION (for slides with custom graphics)
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI image generation uses OPENAI_API_KEY above (no separate key needed)
# Stability AI — optional alternative for image generation
STABILITY_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# SERVER / DEPLOYMENT (optional)
# ─────────────────────────────────────────────────────────────────────────────

PORT=8000
HOST=0.0.0.0
